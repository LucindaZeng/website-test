# WFX Wanfuxin — Environment Variables Template
#
# Copy this file to .env (next to server.py) and fill in real values.
# DO NOT commit .env to git.
#
# This file is an alternative to config.py — use whichever is more convenient
# for your deployment. If both are present, config.py wins.

# ─── Server bind ──────────────────────────────────────────────────────────────
WFX_ENV=production
WFX_HOST=127.0.0.1
WFX_PORT=8000

# ─── MySQL ────────────────────────────────────────────────────────────────────
WFX_DB_HOST=localhost
WFX_DB_PORT=3306
WFX_DB_USER=wfx_user
WFX_DB_PASSWORD=change-this-password
WFX_DB_NAME=wfx_website

# ─── Secrets (REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))") ──
WFX_SESSION_SECRET=replace-with-64-char-random-hex
WFX_ADMIN_TOKEN=replace-with-another-random-string
# Initial admin password — set this on FIRST DEPLOYMENT only, then remove it
# from your .env file after the admin has logged in once and changed it.
# If unset, the legacy default 'wfx6688' is used (also forces change on login).
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(16))"
# WFX_ADMIN_INITIAL_PASSWORD=

# ─── File upload directory ────────────────────────────────────────────────────
# Leave commented to use default ./uploads/quotes/
# WFX_UPLOAD_DIR=/var/www/wanfuxin/uploads/quotes

# ─── Email notifications (SMTP) ───────────────────────────────────────────────
# When a customer submits a quote, the server emails an alert to the address in
# WFX_NOTIFY_EMAIL. If these are left blank/commented, email is skipped
# gracefully — quotes still save to the database and appear in the admin panel
# (Admin → Quotes), so no submission is ever lost.
#
# ── Tencent Enterprise Mail (腾讯企业邮箱) — recommended, since wanfuxin.com
#    is registered at Tencent Cloud ──
#   Host: smtp.exmail.qq.com
#   Port: 465 (SSL) — use this; or 587 for STARTTLS (then set WFX_SMTP_USE_SSL=false)
#   User: your full mailbox address, e.g. lucindaz@wanfuxin.com
#   Password: the CLIENT AUTHORIZATION CODE (客户端授权码 / 客户端专用密码),
#             NOT your normal mailbox login password. Generate it in the mailbox
#             settings: 设置 → 客户端专用密码 → 生成. Tencent requires this for
#             SMTP — your login password will be rejected.
#
# ── Other common providers (if you don't use Tencent enterprise mail) ──
#   Gmail / Google Workspace:  smtp.gmail.com  port 465 SSL  (needs App Password)
#   Microsoft 365 / Outlook:   smtp.office365.com  port 587  WFX_SMTP_USE_SSL=false
#   QQ personal mail:          smtp.qq.com  port 465 SSL  (needs auth code)
#   Aliyun enterprise mail:    smtp.qiye.aliyun.com  port 465 SSL

WFX_SMTP_HOST=smtp.exmail.qq.com
WFX_SMTP_PORT=465
WFX_SMTP_USER=lucindaz@wanfuxin.com
WFX_SMTP_PASSWORD=replace-with-client-authorization-code
WFX_SMTP_USE_SSL=true

# Where quote alerts are delivered. Defaults to lucindaz@wanfuxin.com if unset.
# To notify multiple people, your mailbox can forward, or set a distribution
# address here. (The code currently sends to a single address.)
WFX_NOTIFY_EMAIL=lucindaz@wanfuxin.com

# ─── Site URL (for links inside notification emails) ──────────────────────────
# Your public site URL, no trailing slash. Used to build a clickable
# "manage this quote" link in quote-notification emails. If unset, the email
# just says "Admin → Quotes" without a link.
WFX_SITE_URL=https://wanfuxin-dg.com
