# 3) 301 old .html URLs -> new directory URLs (preserve query string)
location = /services.html { return 301 /services/$is_args$args; }
location = /cnc-milling.html { return 301 /services/cnc-milling/$is_args$args; }
location = /cnc-turning.html { return 301 /services/cnc-turning/$is_args$args; }
